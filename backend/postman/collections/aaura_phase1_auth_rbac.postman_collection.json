    {
      "name": "5 - RBAC smoke (PostgREST)",
      "item": [
        {
          "name": "Events - Club Organizer Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{club_organizer_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizer_id\": \"{{club_organizer_user_id}}\",\n  \"title\": \"AI Study Jam\",\n  \"description\": \"Campus event\",\n  \"location\": \"Main Hall\",\n  \"starts_at\": \"2026-06-15T14:00:00Z\",\n  \"ends_at\": \"2026-06-15T16:00:00Z\",\n  \"capacity\": 120,\n  \"status\": \"draft\"\n}"
            },
            "url": "{{supabase_rest_url}}/events"
          }
        },
        {
          "name": "System Logs - Admin Read",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}" }
            ],
            "url": "{{supabase_rest_url}}/system_logs?select=*&order=created_at.desc&limit=5"
          }
        }
